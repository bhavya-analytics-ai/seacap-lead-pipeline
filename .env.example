# SeaCap Lead Pipeline — copy this to .env and fill in your keys

# CRM — set PUSH_TO=close or PUSH_TO=vanillasoft
PUSH_TO=close

# Close CRM
CLOSE_API_KEY=

# VanillaSoft (only needed if PUSH_TO=vanillasoft)
VANILLASOFT_WEB_LEAD_ID=

# Email verification
MILLIONVERIFIER_API_KEY=

# Business verification
GOOGLE_MAPS_API_KEY=
COBALT_API_KEY=

# Phone verification (Twilio Lookup)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Supabase (pipeline run logs — optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
